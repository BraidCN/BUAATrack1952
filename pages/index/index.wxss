/* 首页样式 */

.hero-section {
  text-align: center;
  padding: 40rpx 0 30rpx;
}

.hero-logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 0 0 8rpx rgba(0,91,172,0.10), 0 0 0 16rpx rgba(0,91,172,0.05);
}

.hero-title {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--primary-blue);
  letter-spacing: 8rpx;
}

.hero-year {
  font-size: 22rpx;
  color: var(--primary-gold);
  letter-spacing: 4rpx;
  margin-top: 4rpx;
}

.hero-subtitle {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 8rpx;
}

.hero-quote {
  font-size: 26rpx;
  color: var(--primary-gold);
  font-style: italic;
  margin-top: 12rpx;
}

.stats-row {
  display: flex;
  justify-content: space-between;
  margin: 20rpx 0 30rpx;
  gap: 12rpx;
}

.stat-card {
  background: linear-gradient(180deg, #ffffff 0%, #faf7f0 100%);
  border: 2rpx solid var(--border-color);
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  flex: 1;
  margin: 0;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.stat-number {
  font-size: 44rpx;
  font-weight: 900;
  color: var(--primary-blue);
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 6rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-dark);
  margin-bottom: 16rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid var(--primary-blue);
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.category-item {
  width: 46%;
  background: #ffffff;
  border: 2rpx solid var(--border-color);
  border-radius: 16rpx;
  padding: 24rpx 0;
  text-align: center;
  margin-bottom: 16rpx;
  font-size: 24rpx;
  color: var(--text-dark);
  position: relative;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
/* 左下角金色折角装饰 */
.category-item::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 0;
  height: 0;
  border-bottom: 24rpx solid var(--primary-gold);
  border-right: 24rpx solid transparent;
  opacity: 0.25;
}

/* ========== 图标系统 V4：北航特色精致图标 ========== */
.ico-box {
  width: 88rpx;
  height: 88rpx;
  margin: 0 auto 10rpx;
  border-radius: 22rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

/* 六种蓝色渐变 */
.ico-build    { background: linear-gradient(135deg, #003d73, #005a9b); }
.ico-research { background: linear-gradient(135deg, #005bac, #0078d4); }
.ico-edu      { background: linear-gradient(135deg, #006ec8, #0088e8); }
.ico-campus   { background: linear-gradient(135deg, #0084d8, #00a0f0); }
.ico-honor    { background: linear-gradient(135deg, #005a9b, #0078d4); }
.ico-ai       { background: linear-gradient(135deg, #004a84, #006ec8); }

/* ====== 1. 建校：殿堂式校门 ====== */
.ico-build-roof {
  position: absolute; top: 12rpx; left: 50%;
  transform: translateX(-50%);
  width: 0; height: 0;
  border-left: 28rpx solid transparent;
  border-right: 28rpx solid transparent;
  border-bottom: 20rpx solid #fff;
}
.ico-build-pillar {
  position: absolute; bottom: 14rpx;
  width: 10rpx; height: 32rpx;
  background: #fff;
  border-radius: 2rpx;
}
.ico-build-pillar-l { left: 22rpx; }
.ico-build-pillar-r { right: 22rpx; }
.ico-build-base {
  position: absolute; bottom: 10rpx; left: 50%;
  transform: translateX(-50%);
  width: 56rpx; height: 6rpx;
  background: #fff;
  border-radius: 3rpx;
}
.ico-build-star {
  position: absolute; top: 18rpx; left: 50%;
  transform: translateX(-50%);
  width: 8rpx; height: 8rpx;
  background: #fff;
  clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
}

/* ====== 2. 科研：火箭（致敬北京二号探空火箭） ====== */
.ico-rocket-head {
  position: absolute; top: 10rpx; left: 50%;
  transform: translateX(-50%);
  width: 0; height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-bottom: 16rpx solid #fff;
}
.ico-rocket-body {
  position: absolute; top: 26rpx; left: 50%;
  transform: translateX(-50%);
  width: 20rpx; height: 34rpx;
  background: #fff;
  border-radius: 0 0 4rpx 4rpx;
}
.ico-rocket-window {
  position: absolute; top: 34rpx; left: 50%;
  transform: translateX(-50%);
  width: 8rpx; height: 8rpx;
  background: var(--primary-blue);
  border-radius: 50%;
}
.ico-rocket-fin-l {
  position: absolute; bottom: 14rpx; left: 22rpx;
  width: 0; height: 0;
  border-top: 14rpx solid transparent;
  border-right: 12rpx solid #fff;
}
.ico-rocket-fin-r {
  position: absolute; bottom: 14rpx; right: 22rpx;
  width: 0; height: 0;
  border-top: 14rpx solid transparent;
  border-left: 12rpx solid #fff;
}
.ico-rocket-flame {
  position: absolute; bottom: 4rpx; left: 50%;
  transform: translateX(-50%);
  width: 0; height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-top: 10rpx solid #fff;
}

/* ====== 3. 教学：打开的书本 ====== */
.ico-book-left {
  position: absolute; top: 22rpx; left: 12rpx;
  width: 28rpx; height: 36rpx;
  background: #fff;
  border-radius: 4rpx 0 0 4rpx;
  transform: skewY(-8deg);
  transform-origin: right center;
}
.ico-book-right {
  position: absolute; top: 22rpx; right: 12rpx;
  width: 28rpx; height: 36rpx;
  background: #fff;
  border-radius: 0 4rpx 4rpx 0;
  transform: skewY(8deg);
  transform-origin: left center;
}
.ico-book-spine {
  position: absolute; top: 20rpx; left: 50%;
  transform: translateX(-50%);
  width: 6rpx; height: 40rpx;
  background: #fff;
  border-radius: 3rpx;
}

/* ====== 4. 校园：学院路主楼（钟楼+窗户） ====== */
.ico-tower-top {
  position: absolute; top: 10rpx; left: 50%;
  transform: translateX(-50%);
  width: 0; height: 0;
  border-left: 14rpx solid transparent;
  border-right: 14rpx solid transparent;
  border-bottom: 14rpx solid #fff;
}
.ico-tower-body {
  position: absolute; top: 24rpx; left: 50%;
  transform: translateX(-50%);
  width: 48rpx; height: 46rpx;
  background: #fff;
  border-radius: 2rpx;
}
.ico-tower-window {
  position: absolute;
  width: 10rpx; height: 10rpx;
  background: var(--primary-blue);
  border-radius: 2rpx;
}
.ico-tower-w1 { top: 30rpx; left: 26rpx; }
.ico-tower-w2 { top: 30rpx; right: 26rpx; }
.ico-tower-w3 { top: 46rpx; left: 26rpx; }
.ico-tower-w4 { top: 46rpx; right: 26rpx; }

/* ====== 5. 荣誉：奖杯（五角星+杯身） ====== */
.ico-trophy-star {
  position: absolute; top: 10rpx; left: 50%;
  transform: translateX(-50%);
  width: 30rpx; height: 30rpx;
  background: #fff;
  clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
}
.ico-trophy-cup {
  position: absolute; top: 38rpx; left: 50%;
  transform: translateX(-50%);
  width: 32rpx; height: 18rpx;
  background: #fff;
  border-radius: 0 0 16rpx 16rpx;
}
.ico-trophy-stem {
  position: absolute; top: 54rpx; left: 50%;
  transform: translateX(-50%);
  width: 8rpx; height: 14rpx;
  background: #fff;
  border-radius: 2rpx;
}
.ico-trophy-base {
  position: absolute; bottom: 10rpx; left: 50%;
  transform: translateX(-50%);
  width: 24rpx; height: 6rpx;
  background: #fff;
  border-radius: 3rpx;
}

/* ====== 7. 每日一史：日历 ====== */
.ico-daily    { background: linear-gradient(135deg, #e67e22, #f39c12); }
.ico-cal-body {
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 44rpx; height: 38rpx;
  border: 4rpx solid #fff;
  border-radius: 6rpx;
  background: transparent;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 4rpx;
}
.ico-cal-ring {
  position: absolute; top: 16rpx;
  width: 8rpx; height: 10rpx;
  background: #fff;
  border-radius: 4rpx 4rpx 0 0;
}
.ico-cal-ring-l { left: 28rpx; }
.ico-cal-ring-r { right: 28rpx; }
.ico-cal-line {
  width: 28rpx;
  height: 3rpx;
  background: #fff;
  border-radius: 2rpx;
}

/* ====== 8. 闯关：旗帜 ====== */
.ico-challenge { background: linear-gradient(135deg, #c0392b, #e74c3c); }
.ico-flag-pole {
  position: absolute; bottom: 14rpx; left: 28rpx;
  width: 4rpx; height: 52rpx;
  background: #fff;
  border-radius: 2rpx;
}
.ico-flag-cloth {
  position: absolute; top: 14rpx; left: 32rpx;
  width: 0; height: 0;
  border-top: 14rpx solid transparent;
  border-bottom: 14rpx solid transparent;
  border-left: 30rpx solid #fff;
}

/* ====== 6. AI：芯片 ====== */
.ico-chip-body {
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 40rpx; height: 40rpx;
  border: 5rpx solid #fff;
  border-radius: 8rpx;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
}
.ico-chip-text {
  color: #fff;
  font-size: 16rpx;
  font-weight: bold;
  letter-spacing: 1rpx;
}
.ico-chip-pin {
  position: absolute;
  background: #fff;
  border-radius: 2rpx;
}
.chip-t { top: 16rpx; left: 50%; transform: translateX(-50%); width: 6rpx; height: 8rpx; }
.chip-b { bottom: 16rpx; left: 50%; transform: translateX(-50%); width: 6rpx; height: 8rpx; }
.chip-l { left: 16rpx; top: 50%; transform: translateY(-50%); width: 8rpx; height: 6rpx; }
.chip-r { right: 16rpx; top: 50%; transform: translateY(-50%); width: 8rpx; height: 6rpx; }

.motto-section {
  text-align: center;
  margin-bottom: 40rpx;
}

.motto-text {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--primary-blue);
  letter-spacing: 6rpx;
  margin: 8rpx 0;
}

.motto-small {
  font-size: 28rpx;
  letter-spacing: 4rpx;
}

.motto-desc {
  font-size: 22rpx;
  color: var(--text-light);
  margin: 6rpx 0;
}

.motto-divider {
  width: 120rpx;
  height: 2rpx;
  background: var(--border-color);
  margin: 16rpx auto;
}
