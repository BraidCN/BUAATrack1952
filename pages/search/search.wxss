/* 搜索页样式 */

.search-box {
  display: flex;
  margin-bottom: 24rpx;
}

.search-input {
  flex: 1;
  height: 80rpx;
  background: #ffffff;
  border: 2rpx solid var(--border-color);
  border-radius: 40rpx 0 0 40rpx;
  padding: 0 28rpx;
  font-size: 26rpx;
  box-shadow: inset 0 2rpx 6rpx rgba(0,0,0,0.04);
}

.search-btn {
  width: 140rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: var(--primary-blue);
  color: #ffffff;
  text-align: center;
  font-size: 28rpx;
  border-radius: 0 40rpx 40rpx 0;
  padding: 0;
  box-shadow: 0 4rpx 12rpx rgba(0,91,172,0.2);
}

.hot-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.hot-tag {
  background: linear-gradient(135deg, #fef9ee, #fef6e0);
  border: 2rpx solid #e8d5b0;
  border-radius: 20rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: #8b6914;
}

.result-year {
  font-size: 44rpx;
  font-weight: 900;
  color: var(--primary-blue);
  width: 100rpx;
  text-align: center;
}

.result-info {
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 16rpx;
}

.search-result-item {
  display: flex;
  padding: 24rpx;
}

.result-year {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--primary-blue);
  width: 100rpx;
  text-align: center;
}

.result-content {
  flex: 1;
  margin-left: 20rpx;
}

.result-title {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-dark);
  margin-bottom: 6rpx;
}

.result-summary {
  font-size: 24rpx;
  color: var(--text-light);
  line-height: 1.5;
}
