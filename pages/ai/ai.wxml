<!-- AI 问答页面 -->
<view class="page-container ai-page">
  <view class="banner-title">AI 问校史</view>

  <scroll-view class="chat-area" scroll-y="true" scroll-into-view="{{scrollToId}}" scroll-with-animation>
    <view wx:for="{{messages}}" wx:key="id" class="message-row {{item.role}}">
      <view class="message-bubble {{item.role}}">
        <text>{{item.content}}</text>
      </view>
    </view>
    <view id="scroll-bottom"></view>
  </scroll-view>

  <view class="quick-questions" wx:if="{{messages.length <= 2}}">
    <view class="section-title">试试这些问题</view>
    <view class="quick-grid">
      <text class="quick-item" bindtap="quickAsk" hover-class="tap-active" data-q="北航什么时候成立的？">北航什么时候成立的？</text>
      <text class="quick-item" bindtap="quickAsk" hover-class="tap-active" data-q="北京一号是什么？">北京一号是什么？</text>
      <text class="quick-item" bindtap="quickAsk" hover-class="tap-active" data-q="校训是什么？">校训是什么？</text>
      <text class="quick-item" bindtap="quickAsk" hover-class="tap-active" data-q="北航有几个校区？">北航有几个校区？</text>
    </view>
  </view>

  <view class="input-area">
    <input class="chat-input" placeholder="输入你想了解的校史问题..."
           bindinput="onInput" value="{{inputValue}}"
           bindconfirm="sendMessage" confirm-type="send"/>
    <button class="send-btn" bindtap="sendMessage" disabled="{{!canSend}}">发送</button>
  </view>
</view>
