/* AI 问答样式 */

.ai-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding-bottom: 0;
}

.chat-area {
  flex: 1;
  padding: 20rpx 0;
  overflow-y: auto;
}

.message-row {
  display: flex;
  margin-bottom: 24rpx;
}

.message-row.user {
  justify-content: flex-end;
}

.message-bubble {
  max-width: 80%;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  line-height: 1.7;
}

.message-bubble.ai {
  background: #ffffff;
  border: 2rpx solid var(--border-color);
  color: var(--text-dark);
  border-bottom-left-radius: 4rpx;
}

.message-bubble.user {
  background: var(--primary-blue);
  color: #ffffff;
  border-bottom-right-radius: 4rpx;
}

.quick-questions {
  padding: 16rpx 0;
}

.quick-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.quick-item {
  background: #ffffff;
  border: 2rpx solid var(--border-color);
  border-radius: 16rpx;
  padding: 14rpx 24rpx;
  font-size: 24rpx;
  color: var(--text-dark);
}

.input-area {
  display: flex;
  padding: 16rpx 0;
  background: var(--bg-warm);
  border-top: 2rpx solid var(--border-color);
}

.chat-input {
  flex: 1;
  height: 72rpx;
  background: #ffffff;
  border: 2rpx solid var(--border-color);
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  box-shadow: inset 0 2rpx 6rpx rgba(0,0,0,0.04);
}

.send-btn {
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: var(--primary-blue);
  color: #ffffff;
  text-align: center;
  font-size: 26rpx;
  border-radius: 36rpx;
  margin-left: 12rpx;
  padding: 0;
  box-shadow: 0 4rpx 12rpx rgba(0,91,172,0.25);
}

.send-btn[disabled] {
  opacity: 0.5;
  box-shadow: none;
}
