/* 时间线样式 */

/* 筛选栏 */
.filter-bar {
  margin-bottom: 20rpx;
}
.filter-scroll {
  white-space: nowrap;
  padding: 8rpx 0;
}
.filter-item {
  display: inline-block;
  padding: 10rpx 24rpx;
  margin-right: 12rpx;
  background: #ffffff;
  border: 2rpx solid var(--border-color);
  border-radius: 30rpx;
  font-size: 24rpx;
  color: var(--text-dark);
  position: relative;
}
.filter-item.filter-active {
  background: var(--primary-blue);
  color: #ffd700;
  border-color: var(--primary-blue);
  font-weight: bold;
  font-size: 26rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,91,172,0.3);
}

.timeline-item {
  display: flex;
  margin-bottom: 10rpx;
  position: relative;
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
  color: var(--text-light);
  font-size: 28rpx;
}

.timeline-left {
  width: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.timeline-year {
  font-size: 32rpx;
  font-weight: 900;
  color: var(--primary-blue);
  margin-top: 20rpx;
}

.timeline-dot {
  width: 16rpx;
  height: 16rpx;
  background: var(--primary-blue);
  border: 4rpx solid #ffd700;
  border-radius: 50%;
  margin-top: 16rpx;
  z-index: 2;
  box-shadow: 0 2rpx 6rpx rgba(0,91,172,0.3);
}

/* 时间线竖线渐变 */
.timeline-left::after {
  content: '';
  position: absolute;
  top: 76rpx;
  width: 2rpx;
  height: calc(100% + 20rpx);
  background: linear-gradient(180deg, var(--primary-blue) 0%, var(--border-color) 20%, var(--border-color) 100%);
  z-index: 1;
}

.timeline-item:last-child .timeline-left::after {
  display: none;
}

.timeline-card {
  flex: 1;
  margin-left: 20rpx;
  padding: 24rpx;
  border-left: 4rpx solid var(--primary-gold);
}

.timeline-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-dark);
  margin: 10rpx 0;
}

.timeline-summary {
  font-size: 24rpx;
  color: var(--text-light);
  line-height: 1.6;
}
